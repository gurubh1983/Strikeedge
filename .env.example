# ============================================================
# StrikeEdge – Environment Configuration
# Copy to .env and fill in your actual values
# Never commit .env to version control!
# ============================================================

STRIKEEDGE_ENVIRONMENT=dev
STRIKEEDGE_DATABASE_URL=sqlite:///./strikeedge.db
STRIKEEDGE_AUTH_MODE=header

# Fyers API – Get credentials from https://myapi.fyers.in/dashboard
STRIKEEDGE_FYERS_APP_ID=your_app_id
STRIKEEDGE_FYERS_SECRET_KEY=your_secret_key
STRIKEEDGE_FYERS_REDIRECT_URI=http://localhost:8000/callback
STRIKEEDGE_FYERS_TOTP_SECRET=

# OpenAI (optional – AI features)
OPENAI_API_KEY=sk-your_openai_key
OPENAI_MODEL=gpt-4o-mini

# Clerk (optional – user auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# URLs (defaults for local dev)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
